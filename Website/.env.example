# Lineforge sports intelligence website
AEGIS_APP_ENV=local
AEGIS_DEV_ERRORS=1

# Product shell
AEGIS_SITE_URL=http://127.0.0.1:8088
AEGIS_SPORTS_DISPLAY_NAME="Lineforge Operator"
AEGIS_SPORTS_TIER=pro
AEGIS_SPORTS_NEW_USER_TIER=pro
AEGIS_SPORTS_TRACKED_GAMES=36
AEGIS_SPORTS_MAX_LEAGUES_PER_REFRESH=16
AEGIS_SPORTS_MODELS=6
AEGIS_SPORTS_REFRESH_SECONDS=20
AEGIS_SPORTS_THEME=aegis-blue
AEGIS_SPORTS_DENSITY=comfortable

# Optional live sportsbook matching
# AEGIS_ODDS_API_KEY=

# Optional compliant execution layer
# Requires PHP OpenSSL for encrypted provider key storage.
# LINEFORGE_CREDENTIAL_KEY=replace-with-32-byte-random-secret
# LINEFORGE_NODE_PATH=node

# Security controls
LINEFORGE_MAX_REQUEST_BYTES=524288
LINEFORGE_HTTP_RATE_LIMIT=600
LINEFORGE_LOGIN_IP_LIMIT=25
LINEFORGE_LOGIN_EMAIL_LIMIT=8
LINEFORGE_REGISTER_IP_LIMIT=8
LINEFORGE_REGISTER_EMAIL_LIMIT=3
LINEFORGE_SESSION_IDLE_SECONDS=28800
LINEFORGE_SESSION_ABSOLUTE_SECONDS=86400
LINEFORGE_SESSION_ROTATE_SECONDS=900

# Optional remote transport escape hatch for local SSL trouble only
# AEGIS_REMOTE_ALLOW_INSECURE_SSL=0
